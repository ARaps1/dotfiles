# This file is symlinked to ~/.config/git/config by stow.
#
# IMPORTANT: Do NOT put work credentials or Benchling-specific
# settings in this public repo. Use includeIf for work-specific config.

[user]
    # TODO: Fill in your personal name and email
    name = Your Name
    email = your.personal@email.com

[core]
    editor = nvim

